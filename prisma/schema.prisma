generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String?  @unique
  pfp          String?
  passwordHash String? // For email/password auth
  role         Role     @default(USER)
  practiceId   String? // Empty for dental lab users
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  practice        Practice?  @relation(fields: [practiceId], references: [id])
  managedPractice Practice[] @relation("PracticeAdmin")
}

model Practice {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff User[]
  admin User[] @relation("PracticeAdmin")
}

enum Role {
  USER
  ADMIN
  PRACTICE_STAFF
  PRACTICE_ADMIN
}
