# Database
DATABASE_URL="postgresql://user:password@localhost:5432/mydb?schema=public"

# Auth
NUXT_SESSION_PASSWORD="replace_with_a_long_random_string"
NUXT_PUBLIC_APP_URL="http://localhost:3000"

# Microsoft Entra ID
NUXT_OAUTH_MICROSOFT_TENANT=""
NUXT_OAUTH_MICROSOFT_CLIENT_ID=""
NUXT_OAUTH_MICROSOFT_CLIENT_SECRET=""

# Storage — set EITHER STORAGE_PATH or the S3_* block; defaults to ./storage/cases
# STORAGE_PATH="./storage/cases"

# S3_BUCKET=""
# S3_REGION="auto"
# S3_ENDPOINT=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
